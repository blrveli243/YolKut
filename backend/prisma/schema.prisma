generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  password           String
  createdAt          DateTime            @default(now())
  age                Int?
  dailyGoal          String?
  gender             String?
  height             Float?
  weight             Float?
  activityLevel      Float?              @default(1.2)
  targetDays         Int?
  targetWeight       Float?
  firstName          String?
  lastName           String?
  photoUrl           String?
  customExercises    CustomExercise[]
  customFoods        CustomFood[]
  foodLogs           FoodLog[]
  goals              Goal[]
  healthData         HealthData[]
  scheduledExercises ScheduledExercise[]
  tasks              Task[]
  wishlists          WishlistItem[]
  runSessions        RunSession[]
  posts              Post[]
  likes              Like[]
  comments           Comment[]
  sentRequests       Friendship[] @relation("SentRequests")
  receivedRequests   Friendship[] @relation("ReceivedRequests")
  sentMessages       Message[]    @relation("SentMessages")
  receivedMessages   Message[]    @relation("ReceivedMessages")
}

model HealthData {
  id             Int      @id @default(autoincrement())
  userId         Int
  steps          Int
  activeCalories Float
  basalCalories  Float
  sleepMinutes   Int
  date           DateTime
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Task {
  id            Int       @id @default(autoincrement())
  userId        Int
  title         String
  isCompleted   Boolean   @default(false)
  date          DateTime
  location      String?
  scheduledTime DateTime?
  goalId        Int?
  goal          Goal?     @relation(fields: [goalId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
}

model Goal {
  id         Int      @id @default(autoincrement())
  userId     Int
  title      String
  category   String
  createdAt  DateTime @default(now())
  targetDays Int
  user       User     @relation(fields: [userId], references: [id])
  tasks      Task[]
}

model FoodLog {
  id       Int      @id @default(autoincrement())
  userId   Int
  name     String
  calories Float
  protein  Float
  carbs    Float
  fat      Float
  sugar    Float
  date     DateTime
  user     User     @relation(fields: [userId], references: [id])
}

model WishlistItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  price       Float?
  link        String?
  orderIndex  Int      @default(0)
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model CustomFood {
  id          Int     @id @default(autoincrement())
  userId      Int
  name        String
  ingredients String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  sugar       Float
  user        User    @relation(fields: [userId], references: [id])
}

model CustomExercise {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  category  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ScheduledExercise {
  id         Int      @id @default(autoincrement())
  userId     Int
  weekday    Int
  exerciseId String
  targetSets Int
  targetReps Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model RunSession {
  id              Int      @id @default(autoincrement())
  userId          Int
  distanceKm      Float
  elapsedSeconds  Int
  targetSpeedKmH  Float?
  averageSpeedKmH Float?
  date            DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model Post {
  id        Int       @id @default(autoincrement())
  userId    Int
  content   String
  imageUrl  String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  likes     Like[]
  comments  Comment[]
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  receiverId  Int
  status      String   @default("pending") // pending, accepted
  createdAt   DateTime @default(now())
  requester   User     @relation("SentRequests", fields: [requesterId], references: [id])
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
